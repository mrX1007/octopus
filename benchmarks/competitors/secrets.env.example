# Copy this file to benchmarks/competitors/secrets.env, keep mode 0600,
# and fill only the providers used by the selected launcher profile.
# Never commit the copied file or real credentials.

# Required acknowledgement for every live campaign. Set this to YES yourself
# only after confirming that the target and every planned action are authorized.
OCTOBENCH_ACK_AUTHORIZED=

# Required operator acknowledgement for live third-party execution: run only
# on a disposable isolated VM/VLAN with no sensitive/private-network route
# beyond the benchmark lab. Set this to YES yourself only after establishing
# that boundary; the launcher requires the exact value YES.
OCTOBENCH_ACK_ISOLATED_HOST=

# Optional lab network overrides. The launcher otherwise detects one private
# host address and binds only that address; standalone labctl defaults to
# 127.0.0.1. Uncomment only when routing requires an explicit interface/port.
# OCTOBENCH_HOST_IP=10.0.0.10
# OCTOBENCH_LAB_BIND=10.0.0.10
# OCTOBENCH_LAB_PORT=8080

# Shared Ollama/Qwen runtime (required by core and extended profiles).
# Use a neutral/raw Qwen tag for both systems. Do not use the repository's
# `octopus-qwen` alias: its embedded OCTOPUS-specific system prompt would bias
# the comparison. Use the exact same already-pulled tag in both fields. A
# sub-70B, distilled or altered/abliterated model is a separately labelled
# small-model stress profile, not a vendor-representative comparison.
# OCTOPUS needs Ollama's generate endpoint; Strix needs the same server origin
# as a base URL and adds its own Ollama chat route. A live launch first checks
# LLM_API_BASE/api/tags and records the selected model's digest and size for
# both systems; this readiness check does not generate text.
OCTOPUS_OLLAMA_URL=
OCTOPUS_OLLAMA_MODEL=

# Strix (required by core and extended profiles). The campaign pins Strix's
# official minutes-scale `quick` scan mode; the campaign still enforces its own
# shared scenario deadline and records the mode in the public manifest.
OCTOBENCH_STRIX_BIN=.benchmark-tools/venvs/strix-1.1.0/bin/strix
STRIX_IMAGE=ghcr.io/usestrix/strix-sandbox@sha256:2e3a7e63a90428979ce34fbf80a8e83bb375d0d1146597a5d74087a259ee925c
STRIX_LLM=
LLM_API_BASE=
# Optional only when the shared endpoint itself requires authentication. Leave
# blank for local Ollama; the explicit blank also clears an inherited shell key.
LLM_API_KEY=

# PentAGI (required only by the extended profile). URL must be private/internal
# and reachable from this host; the service must be release 2.1.0 and must be
# able to reach the private lab URL. Configure all flow-used agent roles to the
# same model declared below; runtime telemetry is checked before publication.
OCTOBENCH_PENTAGI_URL=
OCTOBENCH_PENTAGI_TOKEN=
OCTOBENCH_PENTAGI_PROVIDER=
OCTOBENCH_PENTAGI_MODEL=
# Optional PEM CA bundle for a private HTTPS service using an internal CA.
# Its content digest is recorded in the generated runtime provenance.
# OCTOBENCH_PENTAGI_CA_FILE=/absolute/path/to/internal-ca.pem
