{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/benchmark-scenario-v1.schema.json",
  "title": "OCTOPUS benchmark scenario 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "name",
    "category",
    "lab",
    "target",
    "model",
    "tool_versions",
    "strategy_config",
    "seed",
    "budgets",
    "allowed_actions",
    "ground_truth",
    "artifacts",
    "repetitions"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "scenario_id": {"$ref": "#/$defs/identifier"},
    "name": {"type": "string", "minLength": 1, "maxLength": 4096},
    "category": {
      "enum": [
        "service_discovery_verification",
        "web_api_mapping",
        "credential_discovery_safe_validation",
        "verified_ssh_inventory",
        "authorized_internal_discovery",
        "clean_negative",
        "timeout_partial_result",
        "invalid_empty_llm",
        "crash_resume",
        "contradictions"
      ]
    },
    "lab": {"$ref": "#/$defs/versionedObject"},
    "target": {"$ref": "#/$defs/versionedObject"},
    "model": {
      "type": "object",
      "required": ["provider", "name", "parameters"],
      "properties": {
        "provider": {"type": "string", "minLength": 1, "maxLength": 4096},
        "name": {"type": "string", "minLength": 1, "maxLength": 4096},
        "parameters": {"type": "object", "maxProperties": 256}
      },
      "additionalProperties": true,
      "maxProperties": 256
    },
    "tool_versions": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 256,
      "propertyNames": {"pattern": "^[a-z0-9][a-z0-9_.-]{0,127}$"},
      "additionalProperties": {"type": "string", "minLength": 1, "maxLength": 4096}
    },
    "strategy_config": {"type": "object", "maxProperties": 256},
    "seed": {"type": "integer", "minimum": 0},
    "budgets": {
      "type": "object",
      "required": ["max_tools", "max_seconds", "max_output_bytes"],
      "properties": {
        "max_tools": {"type": "integer", "minimum": 1},
        "max_seconds": {"type": "integer", "minimum": 1},
        "max_output_bytes": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true,
      "maxProperties": 256
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/identifier"}
    },
    "ground_truth": {"type": "object", "maxProperties": 256},
    "artifacts": {"type": "object", "maxProperties": 256},
    "repetitions": {"type": "integer", "minimum": 5},
    "ablations": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "required": ["toggle", "values"],
        "properties": {
          "toggle": {"$ref": "#/$defs/identifier"},
          "values": {"type": "array", "minItems": 2, "maxItems": 256}
        },
        "additionalProperties": true,
        "maxProperties": 256
      }
    },
    "tags": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/identifier"}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]{0,127}$"
    },
    "versionedObject": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": {"type": "string", "minLength": 1, "maxLength": 4096}
      },
      "additionalProperties": true,
      "maxProperties": 256
    }
  }
}
