{
  "$id": "https://octopus.local/schemas/benchmark-analysis-plan-v3.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "alpha": { "exclusiveMaximum": 1, "exclusiveMinimum": 0, "type": "number" },
    "batches": { "minimum": 1, "type": "integer" },
    "bootstrap_samples": { "minimum": 100, "type": "integer" },
    "bootstrap_seed": { "minimum": 0, "type": "integer" },
    "comparison_pairs": {
      "items": {
        "items": { "$ref": "#/$defs/identifier" },
        "maxItems": 2,
        "minItems": 2,
        "type": "array"
      },
      "minItems": 1,
      "type": "array"
    },
    "deadlines_seconds": { "items": { "exclusiveMinimum": 0, "type": "number" }, "minItems": 1, "type": "array" },
    "exclusion_rules": { "items": { "type": "string" }, "type": "array" },
    "fixture_seeds": {
      "additionalProperties": { "items": { "minimum": 0, "type": "integer" }, "type": "array" },
      "type": "object"
    },
    "frozen": { "const": true },
    "hosts": { "minimum": 1, "type": "integer" },
    "metrics": { "items": { "$ref": "#/$defs/identifier" }, "minItems": 1, "type": "array" },
    "paired_blocks": { "minimum": 0, "type": "integer" },
    "plan_digest": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "plan_id": { "$ref": "#/$defs/identifier" },
    "populations": { "items": { "enum": ["all_scheduled", "completion_conditional"] }, "minItems": 1, "type": "array" },
    "publication_tier": { "enum": ["diagnostic", "canary", "full"] },
    "repetitions": { "minimum": 1, "type": "integer" },
    "require_run_plan_attestation": { "type": "boolean" },
    "scenario_ids": { "items": { "$ref": "#/$defs/identifier" }, "minItems": 1, "type": "array" },
    "schema_version": { "const": "1.0" },
    "system_ids": { "items": { "$ref": "#/$defs/identifier" }, "minItems": 2, "type": "array" },
    "track_id": { "$ref": "#/$defs/identifier" }
  },
  "required": ["alpha", "batches", "bootstrap_samples", "bootstrap_seed", "comparison_pairs", "deadlines_seconds", "exclusion_rules", "fixture_seeds", "frozen", "hosts", "metrics", "paired_blocks", "plan_digest", "plan_id", "populations", "publication_tier", "repetitions", "require_run_plan_attestation", "scenario_ids", "schema_version", "system_ids", "track_id"],
  "title": "OCTOPUS Benchmark v3 frozen analysis plan",
  "type": "object",
  "$defs": {
    "identifier": { "pattern": "^[a-z0-9][a-z0-9_.:-]{0,159}$", "type": "string" }
  }
}
