{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.local/schemas/benchmark-system-v1.schema.json",
  "title": "OCTOPUS competitor benchmark system manifest 1.0",
  "description": "A versioned system-under-test declaration for an authorized competitor benchmark campaign.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "system_id",
    "name",
    "version",
    "source_revision",
    "execution_mode",
    "track",
    "fairness_profile",
    "model",
    "tool_versions",
    "adapter"
  ],
  "properties": {
    "$schema": {"type": "string", "minLength": 1, "maxLength": 4096},
    "schema_version": {"const": "1.0"},
    "system_id": {"$ref": "#/$defs/identifier"},
    "name": {"type": "string", "minLength": 1, "maxLength": 4096},
    "version": {"type": "string", "minLength": 1, "maxLength": 4096},
    "source_revision": {"type": "string", "minLength": 1, "maxLength": 4096},
    "execution_mode": {"enum": ["live", "replay"]},
    "track": {"enum": ["framework_only", "full_system"]},
    "fairness_profile": {
      "type": "object",
      "required": [
        "profile_id",
        "same_model",
        "same_tool_versions",
        "same_hardware",
        "same_budgets"
      ],
      "properties": {
        "profile_id": {"$ref": "#/$defs/identifier"},
        "same_model": {"type": "boolean"},
        "same_tool_versions": {"type": "boolean"},
        "same_hardware": {"type": "boolean"},
        "same_budgets": {"type": "boolean"},
        "notes": {"type": "string", "maxLength": 4096}
      },
      "additionalProperties": false
    },
    "model": {
      "type": "object",
      "required": ["provider", "name", "parameters"],
      "properties": {
        "provider": {"type": "string", "minLength": 1, "maxLength": 4096},
        "name": {"type": "string", "minLength": 1, "maxLength": 4096},
        "parameters": {"type": "object", "maxProperties": 256}
      },
      "additionalProperties": true,
      "maxProperties": 256
    },
    "tool_versions": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 256,
      "propertyNames": {"pattern": "^[a-z0-9][a-z0-9_.-]{0,127}$"},
      "additionalProperties": {"type": "string", "minLength": 1, "maxLength": 4096}
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "argv",
        "working_directory",
        "environment_passthrough"
      ],
      "properties": {
        "kind": {"const": "command"},
        "argv": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "description": "Shell-free argv. Allowed placeholders are {scenario_path}, {output_path}, {repetition}, {seed}, and {system_id}; scenario_path and output_path are required.",
          "items": {"type": "string", "minLength": 1, "maxLength": 4096},
          "allOf": [
            {"contains": {"type": "string", "pattern": "\\{scenario_path\\}"}},
            {"contains": {"type": "string", "pattern": "\\{output_path\\}"}}
          ]
        },
        "working_directory": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "environment_passthrough": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
            "maxLength": 128,
            "not": {"pattern": "^OCTOPUS_BENCHMARK_"}
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "maxProperties": 256
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"track": {"const": "framework_only"}},
        "required": ["track"]
      },
      "then": {
        "properties": {
          "fairness_profile": {
            "properties": {
              "same_model": {"const": true},
              "same_tool_versions": {"const": true},
              "same_hardware": {"const": true},
              "same_budgets": {"const": true}
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]{0,127}$"
    }
  }
}
