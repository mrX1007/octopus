{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus.invalid/schemas/dependency-lock-manifest-v1.json",
  "title": "OCTOPUS dependency lock manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "state",
    "epoch",
    "resolver",
    "policy",
    "targets",
    "profiles",
    "input_sha256",
    "locks"
  ],
  "properties": {
    "$schema": {"const": "manifest.schema.json"},
    "schema_version": {"const": 1},
    "state": {"enum": ["unresolved", "resolved"]},
    "epoch": {"const": "2026-07-24T00:00:00Z"},
    "resolver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "name", "version"],
      "properties": {
        "index": {"const": "https://pypi.org/simple"},
        "name": {"const": "uv"},
        "version": {"const": "0.11.28"}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow_direct_references", "require_hashes", "sdist_policy"],
      "properties": {
        "allow_direct_references": {"const": false},
        "require_hashes": {"const": true},
        "sdist_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["default", "allowlist_by_profile"],
          "properties": {
            "default": {"const": "deny"},
            "allowlist_by_profile": {
              "type": "object",
              "additionalProperties": false,
              "required": ["runtime", "c2", "reporting", "osint-browser", "test", "mysql", "external-tools", "platform", "full"],
              "properties": {
                "runtime": {"const": []},
                "c2": {"const": []},
                "reporting": {"const": []},
                "osint-browser": {"const": ["shodan"]},
                "test": {"const": []},
                "mysql": {"const": []},
                "external-tools": {"const": []},
                "platform": {"const": []},
                "full": {"const": ["shodan"]}
              }
            }
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/target"}
    },
    "profiles": {
      "type": "object",
      "minProperties": 9,
      "maxProperties": 9,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {"type": "string", "pattern": "^requirements/[A-Za-z0-9._-]+\\.txt$"}
      }
    },
    "input_sha256": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/sha256"}
    },
    "locks": {
      "type": "array",
      "minItems": 27,
      "maxItems": 27,
      "items": {"$ref": "#/$defs/lock"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "python_version", "implementation", "platform", "python_platform"],
      "properties": {
        "tag": {"enum": ["cp310", "cp311", "cp312"]},
        "python_version": {"enum": ["3.10", "3.11", "3.12"]},
        "implementation": {"const": "cpython"},
        "platform": {"const": "linux-x86_64"},
        "python_platform": {"const": "x86_64-manylinux_2_34"}
      }
    },
    "lock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "target", "profile", "sha256", "input_sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^requirements/locks/linux-x86_64/cp(310|311|312)/(runtime|c2|reporting|osint-browser|test|mysql|external-tools|platform|full)\\.txt$"
        },
        "target": {"enum": ["cp310", "cp311", "cp312"]},
        "profile": {"enum": ["runtime", "c2", "reporting", "osint-browser", "test", "mysql", "external-tools", "platform", "full"]},
        "sha256": {"$ref": "#/$defs/sha256"},
        "input_sha256": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/sha256"}
        }
      }
    }
  }
}
