# ═══════════════════════════════════════════════
# Octopus — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# Shodan API Key (get from https://shodan.io)
SHODAN_API_KEY=YOUR_KEY_HERE

# C2 Server Configuration
OCTOPUS_C2_HOST=127.0.0.1
OCTOPUS_C2_PORT=8443
OCTOPUS_C2_PSK=change_me_to_random_string

# Database (overrides config.yaml values)
OCTOPUS_DB_HOST=localhost
OCTOPUS_DB_USER=octopus
OCTOPUS_DB_PASS=
OCTOPUS_DB_NAME=octopus

# Ollama (overrides config.yaml values)
# OCTOPUS_OLLAMA_URL=http://localhost:11434/api/generate
# OCTOPUS_OLLAMA_MODEL=octopus-qwen
